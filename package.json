{
  "name": "keriwasm-web-payload",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node tools/gen-bridge-contract.mjs",
    "build": "vite build",
    "build:ci": "node tools/gen-bridge-contract.mjs && vite build && node tools/gen-build-manifest.mjs",
    "bridge:check": "node tools/gen-bridge-contract.mjs --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": "22.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "typescript": "5.7.3",
    "vite": "6.1.0",
    "vitest": "^4.0.18"
  }
}
