{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$comment": "Single source of truth for JS ↔ Swift bridge constants. Run `node tools/gen-bridge-contract.mjs` to regenerate BridgeContract.swift and src/bridge-contract.ts.",
    "version": "1.0",
    "bridge": {
        "handlerName": "bridge"
    },
    "lifecycleStates": [
        "boot",
        "pyodide_loading",
        "crypto_ready",
        "ready",
        "error"
    ],
    "bridgeMessageTypes": [
        "js_error",
        "unhandled_rejection",
        "log",
        "lifecycle",
        "crypto_result"
    ],
    "workerCommandTypes": [
        "init",
        "blake3_hash",
        "sign",
        "verify",
        "db_put",
        "db_get",
        "db_del",
        "db_list"
    ],
    "workerResultTypes": [
        "ready",
        "blake3_result",
        "sign_result",
        "verify_result",
        "db_put_result",
        "db_get_result",
        "db_del_result",
        "db_list_result",
        "error",
        "log"
    ]
}
