# Xcode / Swift
.DS_Store
*.xcuserstate
*.xcuserdata/
DerivedData/
build/

# Xcode per-user state inside nested projects
xcodeproj/**/xcuserdata/

# Bundled web payload output should not be committed.
# Keep the directory via .gitkeep.
WebPayload/*
!WebPayload/.gitkeep

# Optional local overrides (debug-only) should never be committed.
WebPayloadOverride/*
!WebPayloadOverride/.gitkeep

# Web payload build outputs (never commit)
dist/
node_modules/

# Pyodide runtime (downloaded at build time via make pyodide)
public/pyodide/

# Python / misc
__pycache__/
*.pyc
*.pyo
.envrc

# IDE
.sourcekit-lsp/
*.swp
